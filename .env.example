# ---------------------------------------------------------------------------
# Exemplo de variáveis de ambiente do back-end (apps/api).
# Copia este ficheiro para apps/api/.env e preenche os valores reais.
# Nenhum valor real deve ser commitado.
# ---------------------------------------------------------------------------

# Ambiente: development | test | production
NODE_ENV=development

# Servidor HTTP
PORT=3333
# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173

# Base de dados PostgreSQL
DATABASE_URL=postgresql://kinguila:kinguila@localhost:5432/kinguila

# Autenticação (Identity)
# Segredo para assinar os JWT. Em produção usa um valor longo e aleatório.
JWT_SECRET=troca-este-segredo-em-producao
# Duração do access token (ex.: 15m, 1h, 7d)
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ---------------------------------------------------------------------------
# Integrações externas
# Cada fornecedor (taxas, pagamentos, KYC...) tem o seu bloco de variáveis.
# ---------------------------------------------------------------------------

# Provedor de taxas de câmbio de referência (integração de exemplo)
EXCHANGE_RATE_API_URL=https://api.exchangerate.example/
EXCHANGE_RATE_API_KEY=

# Envio de email (Resend) — obrigatório em produção (RESEND_API_KEY e EMAIL_FROM).
# Em desenvolvimento podem ficar vazios: a app arranca, mas não envia emails reais.
RESEND_API_URL=https://api.resend.com/
RESEND_API_KEY=
# Remetente verificado na Resend (ex.: "Kinguila <no-reply@kinguila.app>")
EMAIL_FROM=Kinguila <no-reply@kinguila.app>

# Verificação de conta e reset de senha
# URL base do front-end, usada para montar o link de reset (ex.: https://app.kinguila.com)
WEB_APP_URL=http://localhost:5173
# Validade do código de confirmação e do token de reset (ex.: 15m, 1h)
EMAIL_CODE_TTL=15m
PASSWORD_RESET_TOKEN_TTL=1h
# Janela mínima entre reenvios de código (segundos) e nº de tentativas antes do lockout
EMAIL_RESEND_RATE_LIMIT_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
